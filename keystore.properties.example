# Release signing config template.
#
# Copy this file to `keystore.properties` (repo root) and fill in the real values.
# The real `keystore.properties` is gitignored and must never be committed.
#
# Env vars take priority over this file (used by CI): KEYSTORE_FILE,
# KEYSTORE_PASSWORD, KEY_ALIAS, KEY_PASSWORD.
#
# storeFile: path to the .keystore file. Relative paths resolve against the app/
# module directory (so `swing-music-release.keystore` => app/swing-music-release.keystore),
# or use an absolute path.

storeFile=swing-music-release.keystore
storePassword=your_keystore_password
keyAlias=your_key_alias
keyPassword=your_key_password
